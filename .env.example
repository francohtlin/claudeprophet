# ClaudeProphet environment template. Copy to .env and fill in as needed.
# A local .env is ignored by Git. Do not commit real secrets.

# --- Claude runtime (local subscription auth; no API key) ---
# ClaudeProphet forecasts run on the local Claude subscription (Claude Code
# login / OAuth). Log in once with `claude login`, OR provide a generated
# subscription token from `claude setup-token`:
# CLAUDE_CODE_OAUTH_TOKEN=

# Model + agent behavior
CLAUDE_FORECAST_MODEL=claude-opus-4-8
# Permission mode passed to the claude CLI. bypassPermissions runs tools without
# prompts so the agent can reach network evidence tools non-interactively.
CLAUDE_FORECAST_PERMISSION_MODE=bypassPermissions
CLAUDE_FORECAST_MAX_TURNS=200

# Timeouts (seconds). CLAUDE_API_TIMEOUT is the process lifecycle kill switch.
CLAUDE_API_TIMEOUT=540
CLAUDE_EVALUATION_TIMEOUT=600
CLAUDE_FORECAST_RETURN_BUFFER_SECONDS=20

# Optional: isolate Claude config/credentials to a dedicated directory.
# CLAUDEPROPHET_CLAUDE_CONFIG_DIR=

# --- Prophet server (optional) ---
# PA_SERVER_API_KEY=
# PROPHETHACKS_SERVER_API_KEY=

# --- Optional evidence provider keys ---
# THE_ODDS_API_KEY=
# FRED_API_KEY=
# FINNHUB_API_KEY=
# ALPHA_VANTAGE_API_KEY=

# --- Optional OpenRouter fallback (disabled by default) ---
# Only used when a Claude run exits nonzero AND CLAUDE_ALLOW_OPENROUTER_FALLBACK is on.
# CLAUDE_ALLOW_OPENROUTER_FALLBACK=false
# OPENROUTER_API_KEY=
# OPENROUTER_FALLBACK_MODEL=anthropic/claude-opus-4
